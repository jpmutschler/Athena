# Athena Environment Variables
# Copy to .env and adjust for your environment.

# ── Library Path ─────────────────────────────────────────────────────────
# Override the default library search order with an explicit directory.
# The loader searches (in order):
#   1. SWITCHTEC_LIB_DIR  (this variable)
#   2. <package>/_native/  (pre-built wheel)
#   3. vendor/switchtec/lib/  (dev/editable install)
#   4. System paths (/usr/local/lib, /usr/lib, etc.)
# SWITCHTEC_LIB_DIR=/opt/switchtec/lib

# ── API Authentication ───────────────────────────────────────────────────
# Optional. When set, all API requests must include an X-API-Key header
# with this value. Uses HMAC-SHA256 constant-time comparison.
# Leave unset to disable authentication (development only).
# SWITCHTEC_API_KEY=your-secret-key-here

# ── Server Configuration ────────────────────────────────────────────────
# Host and port are set via CLI flags, not environment variables:
#   athena serve --host 0.0.0.0 --port 8000
# CORS origins default to localhost:8000 and 127.0.0.1:8000.

# ── Logging ──────────────────────────────────────────────────────────────
# Structured logging level. Options: DEBUG, INFO, WARNING, ERROR.
# ATHENA_LOG_LEVEL=INFO
