resources/switchtec-user-4.4-rc2/build/

# Native libraries (built by CI, embedded in wheels)
src/serialcables_switchtec/_native/*.dll
src/serialcables_switchtec/_native/*.so
src/serialcables_switchtec/_native/*.so.*
src/serialcables_switchtec/_native/*.dylib

